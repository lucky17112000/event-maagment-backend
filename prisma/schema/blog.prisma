model Blog {
    id        String   @id @default(uuid())
    title     String
    content   String
    authorId  String
    Image     String?
    views     Int      @default(0)
    author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([authorId])
    @@map("blogs")
}
